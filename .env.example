# Salin file ini menjadi ".env" lalu isi dengan kredensial project Supabase kamu.
# Ambil dari: Supabase Dashboard > Project Settings > API
#
# PENTING: hanya pakai ANON key di frontend. JANGAN pernah menaruh service_role key di sini.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
